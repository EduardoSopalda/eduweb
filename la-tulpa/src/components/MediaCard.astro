---
import { type Locale } from '../i18n';

interface Props {
  title: string;
  type: 'video' | 'audio' | 'image' | 'text' | 'banner';
  description?: string;
  url?: string;
  thumbnail?: string;
  thumbnailAlt?: string;
  locale: Locale;
}

const { title, type, description, url, thumbnail, thumbnailAlt, locale } = Astro.props;

const typeLabels: Record<string, Record<string, string>> = {
  video: { es: 'Vídeo', en: 'Video' },
  audio: { es: 'Audio', en: 'Audio' },
  image: { es: 'Imagen', en: 'Image' },
  text: { es: 'Texto', en: 'Text' },
  banner: { es: 'Banner', en: 'Banner' },
};
---

<article class="media-card reveal" data-type={type}>
  <div class="media-thumb">
    {thumbnail ? (
      <img src={thumbnail} alt={thumbnailAlt || title} loading="lazy" />
    ) : (
      <div class="media-thumb--placeholder" role="img" aria-label={title}>
        <span class="media-type-icon">{type === 'video' ? '▶' : type === 'audio' ? '♪' : type === 'image' ? '◻' : type === 'banner' ? '▬' : '¶'}</span>
      </div>
    )}
  </div>
  <div class="media-info">
    <span class="media-type-label">{typeLabels[type]?.[locale] || type}</span>
    <h3 class="media-title">{title}</h3>
    {description && <p class="media-desc">{description}</p>}
    {url ? (
      <a href={url} class="media-link" target="_blank" rel="noopener noreferrer">
        {locale === 'es' ? 'Ver recurso' : 'View resource'}
        <span class="sr-only"> ({locale === 'es' ? 'se abre en ventana nueva' : 'opens in new window'})</span>
      </a>
    ) : (
      <p class="media-pending">
        {locale === 'es' ? 'Recurso pendiente' : 'Resource pending'}
      </p>
    )}
  </div>
</article>

<style>
  .media-card {
    background-color: var(--color-bg-elevated);
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: border-color 0.2s ease;
  }

  .media-card:hover {
    border-color: var(--color-accent);
  }

  .media-thumb {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--color-bg-card);
  }

  .media-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .media-thumb--placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .media-type-icon {
    font-size: 2rem;
    color: var(--color-accent);
    opacity: 0.5;
  }

  .media-info {
    padding: var(--space-sm);
  }

  .media-type-label {
    display: inline-block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-light);
    margin-bottom: var(--space-xs);
  }

  .media-title {
    font-size: 1.1rem;
    margin-bottom: var(--space-xs);
    font-family: var(--font-body);
    font-weight: 600;
  }

  .media-desc {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .media-link {
    display: inline-block;
    margin-top: var(--space-xs);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .media-pending {
    margin-top: var(--space-xs);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }
</style>
