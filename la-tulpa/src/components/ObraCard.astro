---
import { type Locale, t } from '../i18n';

interface Props {
  title: string;
  year: number;
  type: string;
  synopsis: string;
  slug: string;
  image?: string;
  imageAlt?: string;
  locale: Locale;
}

const { title, year, type, synopsis, slug, image, imageAlt, locale } = Astro.props;
const href = locale === 'es' ? `/obras/${slug}` : `/en/works/${slug}`;
---

<article class="obra-card reveal">
  {image ? (
    <div class="obra-image">
      <img src={image} alt={imageAlt || title} loading="lazy" />
    </div>
  ) : (
    <div class="obra-image obra-image--placeholder" role="img" aria-label={title}>
      <span class="obra-year-display">{year}</span>
    </div>
  )}
  <div class="obra-info">
    <span class="obra-year">{year}</span>
    <h3 class="obra-title">{title}</h3>
    <p class="obra-type">{type}</p>
    <p class="obra-synopsis">{synopsis}</p>
    <a href={href} class="obra-link">
      {t(locale, 'works.viewWork')}
      <span aria-hidden="true">&rarr;</span>
    </a>
  </div>
</article>

<style>
  .obra-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .obra-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 4px;
    background-color: var(--color-bg-elevated);
  }

  .obra-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .obra-image--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px dashed var(--color-border);
  }

  .obra-year-display {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--color-accent);
    opacity: 0.4;
  }

  .obra-year {
    font-size: 0.85rem;
    color: var(--color-accent-light);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .obra-title {
    font-size: 1.6rem;
    margin: var(--space-xs) 0;
  }

  .obra-type {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    font-style: italic;
    margin-bottom: var(--space-xs);
  }

  .obra-synopsis {
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.6;
  }

  .obra-link {
    display: inline-block;
    margin-top: var(--space-sm);
    font-size: 0.95rem;
    font-weight: 600;
  }

  @media (min-width: 768px) {
    .obra-card {
      grid-template-columns: 1fr 1.2fr;
      align-items: start;
    }
  }
</style>
