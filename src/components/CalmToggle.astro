---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<button
  class="calm-toggle"
  type="button"
  aria-pressed="false"
  aria-label={t('calm.label')}
  title={t('calm.label')}
  data-label-calm={t('calm.label')}
  data-label-chaos={t('chaos.label')}
>
  <span class="calm-toggle-icon" aria-hidden="true"></span>
  <span class="calm-toggle-text">{t('calm.label')}</span>
</button>

<script>
  function initCalmToggleLabel() {
    const btn = document.querySelector('.calm-toggle') as HTMLButtonElement;
    if (!btn) return;
    const textEl = btn.querySelector('.calm-toggle-text') as HTMLElement;
    if (!textEl) return;

    const calmLabel = btn.dataset.labelCalm || 'Calm mode';
    const chaosLabel = btn.dataset.labelChaos || 'Chaos mode';

    function updateLabel() {
      const isChaos = document.documentElement.classList.contains('chaos');
      const label = isChaos ? chaosLabel : calmLabel;
      textEl.textContent = label;
      btn.setAttribute('aria-label', label);
      btn.title = label;
    }

    updateLabel();

    const observer = new MutationObserver(updateLabel);
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  }

  initCalmToggleLabel();
  document.addEventListener('astro:after-swap', initCalmToggleLabel);
</script>

<style>
  .calm-toggle {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: none;
    border: 1px solid var(--color-warm-grey-light);
    border-radius: 2px;
    padding: 0.3em 0.7em;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .calm-toggle:hover {
    color: var(--color-text);
    border-color: var(--color-text-secondary);
  }

  .calm-toggle[aria-pressed="true"] {
    color: var(--color-accent-interactive);
    border-color: var(--color-accent);
  }

  .calm-toggle-icon {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-warm-grey-light);
    transition: background-color var(--transition-fast);
  }

  .calm-toggle[aria-pressed="true"] .calm-toggle-icon {
    background-color: var(--color-accent-interactive);
  }

  .calm-toggle-text {
    display: none;
  }

  @media (min-width: 64rem) {
    .calm-toggle-text {
      display: inline;
    }
  }
</style>
