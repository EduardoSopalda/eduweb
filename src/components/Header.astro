---
import { getLangFromUrl, useTranslations, getLocalePath, getAlternateUrl, getAlternateLang } from '../i18n/utils';
import { languages } from '../i18n/ui';
import CalmToggle from './CalmToggle.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const alternateLang = getAlternateLang(lang);
const alternateUrl = getAlternateUrl(Astro.url, lang);

const navItems = [
  { label: t('nav.about'), href: getLocalePath('/sobre', lang), num: 'I' },
  { label: t('nav.work'), href: getLocalePath('/obra', lang), num: 'II' },
  { label: t('nav.schedule'), href: getLocalePath('/agenda', lang), num: 'III' },
  { label: t('nav.press'), href: getLocalePath('/prensa', lang), num: 'IV' },
  { label: t('nav.contact'), href: getLocalePath('/contacto', lang), num: 'V' },
];
---

<header class="site-header" role="banner">
  <div class="header-inner container">
    <a href={getLocalePath('/', lang)} class="site-logo" aria-label="Manuel Monrò — Inicio">
      <span class="logo-name">Manuel Monrò</span>
    </a>
    <div class="header-actions">
      <CalmToggle />
      <button
        class="nav-trigger"
        aria-expanded="false"
        aria-controls="nav-curtain"
        aria-label={t('nav.menu')}
        type="button"
      >
        <span class="nav-trigger-bar" aria-hidden="true"></span>
        <span class="nav-trigger-bar" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</header>

<div id="nav-curtain" class="curtain" role="dialog" aria-modal="true" aria-label={lang === 'es' ? 'Navegación' : 'Navigation'} hidden>
  <nav class="curtain-nav" aria-label={lang === 'es' ? 'Navegación principal' : 'Main navigation'}>
    <ul class="curtain-list" role="list">
      {navItems.map((item) => (
        <li class="curtain-item">
          <span class="curtain-num marginalia">{item.num}</span>
          <a href={item.href} class="curtain-link">{item.label}</a>
        </li>
      ))}
    </ul>
    <div class="curtain-footer">
      <a href={alternateUrl} class="curtain-lang" lang={alternateLang} hreflang={alternateLang}>
        {languages[alternateLang]}
      </a>
      <p class="curtain-verse marginalia">
        {lang === 'es'
          ? 'Los cuerdos de atar preparan la soga de mi juicio final.'
          : 'The sane ones tie the rope for my final judgment.'}
      </p>
    </div>
  </nav>
</div>

<script>
  function initCurtain() {
    const trigger = document.querySelector('.nav-trigger') as HTMLButtonElement;
    const curtain = document.getElementById('nav-curtain') as HTMLElement;
    if (!trigger || !curtain) return;

    let focusableEls: HTMLElement[] = [];
    let firstFocusable: HTMLElement | null = null;
    let lastFocusable: HTMLElement | null = null;

    function open() {
      curtain.hidden = false;
      trigger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';

      focusableEls = Array.from(
        curtain.querySelectorAll<HTMLElement>('a[href], button, [tabindex]:not([tabindex="-1"])')
      );
      firstFocusable = focusableEls[0] || null;
      lastFocusable = focusableEls[focusableEls.length - 1] || null;

      requestAnimationFrame(() => {
        curtain.classList.add('is-open');
        if (firstFocusable) firstFocusable.focus();
      });
    }

    function close() {
      curtain.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';

      const onEnd = () => {
        curtain.hidden = true;
        curtain.removeEventListener('transitionend', onEnd);
      };

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        curtain.hidden = true;
      } else {
        curtain.addEventListener('transitionend', onEnd, { once: true });
        setTimeout(() => { curtain.hidden = true; }, 800);
      }

      trigger.focus();
    }

    trigger.addEventListener('click', () => {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      isOpen ? close() : open();
    });

    curtain.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') { close(); return; }
      if (e.key !== 'Tab') return;

      if (e.shiftKey) {
        if (document.activeElement === firstFocusable) {
          e.preventDefault();
          lastFocusable?.focus();
        }
      } else {
        if (document.activeElement === lastFocusable) {
          e.preventDefault();
          firstFocusable?.focus();
        }
      }
    });

    curtain.querySelectorAll('.curtain-link').forEach(link => {
      link.addEventListener('click', () => close());
    });
  }

  let scrollHandler: (() => void) | null = null;

  function initHeaderScroll() {
    const header = document.querySelector('.site-header') as HTMLElement;
    if (!header) return;

    if (scrollHandler) {
      window.removeEventListener('scroll', scrollHandler);
    }

    let lastY = window.scrollY;

    scrollHandler = () => {
      const y = window.scrollY;
      if (y > 80 && y > lastY) {
        header.classList.add('header-hidden');
      } else {
        header.classList.remove('header-hidden');
      }
      lastY = y;
    };

    window.addEventListener('scroll', scrollHandler, { passive: true });
  }

  initCurtain();
  initHeaderScroll();
  document.addEventListener('astro:after-swap', () => {
    initCurtain();
    initHeaderScroll();
  });
</script>

<style>
  /* Header bar — minimal in repose */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: rgba(10, 10, 12, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-bronze-subtle, rgba(139, 111, 71, 0.15));
    transition: transform var(--transition-base);
  }

  html:not(.chaos) .site-header {
    background-color: rgba(245, 242, 237, 0.9);
  }

  .header-hidden {
    transform: translateY(-100%);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-sm);
    gap: var(--space-sm);
  }

  .site-logo {
    background-image: none;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .site-logo:hover { background-image: none; }

  .logo-name {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  /* Trigger button */
  .nav-trigger {
    display: flex;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-xs);
    position: relative;
    z-index: 200;
  }

  .nav-trigger-bar {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-text);
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  .nav-trigger[aria-expanded="true"] .nav-trigger-bar:nth-child(1) {
    transform: translateY(4px) rotate(45deg);
  }

  .nav-trigger[aria-expanded="true"] .nav-trigger-bar:nth-child(2) {
    transform: translateY(-4px) rotate(-45deg);
  }

  /* Fullscreen curtain */
  .curtain[hidden] {
    display: none !important;
  }

  .curtain {
    position: fixed;
    inset: 0;
    z-index: 150;
    background-color: rgba(10, 10, 12, 0.97);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  html:not(.chaos) .curtain {
    background-color: rgba(245, 242, 237, 0.98);
  }

  .curtain.is-open {
    opacity: 1;
  }

  .curtain-nav {
    width: 100%;
    max-width: var(--max-width);
    padding-inline: var(--space-md);
  }

  .curtain-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .curtain-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    opacity: 0;
    transform: translateY(1rem);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .is-open .curtain-item {
    opacity: 1;
    transform: none;
  }

  .is-open .curtain-item:nth-child(1) { transition-delay: 0.1s; }
  .is-open .curtain-item:nth-child(2) { transition-delay: 0.15s; }
  .is-open .curtain-item:nth-child(3) { transition-delay: 0.2s; }
  .is-open .curtain-item:nth-child(4) { transition-delay: 0.25s; }
  .is-open .curtain-item:nth-child(5) { transition-delay: 0.3s; }

  @media (prefers-reduced-motion: reduce) {
    .curtain-item {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .curtain {
      transition: none;
    }
  }

  .curtain-num {
    font-size: 0.7rem;
    min-width: 2rem;
    text-align: right;
  }

  .curtain-link {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 700;
    color: var(--color-text);
    background-image: none;
    text-decoration: none;
    position: relative;
    display: inline-block;
    line-height: 1.2;
    transition: color var(--transition-fast);
  }

  .curtain-link::after {
    content: '';
    position: absolute;
    bottom: 0.05em;
    left: 0;
    width: 0;
    height: 4px;
    background-color: var(--color-accent-solid);
    transition: width 0.3s ease;
  }

  .curtain-link:hover {
    color: var(--color-accent-interactive);
    background-image: none;
  }

  .curtain-link:hover::after {
    width: 100%;
  }

  .curtain-link:focus-visible {
    outline: 2px solid var(--color-focus-ring);
    outline-offset: 4px;
  }

  .curtain-footer {
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-warm-grey);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--space-md);
    opacity: 0;
    transition: opacity 0.4s ease 0.35s;
  }

  .is-open .curtain-footer {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .curtain-footer {
      opacity: 1;
      transition: none;
    }
  }

  .curtain-lang {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-interactive);
    background-image: none;
  }

  .curtain-lang:hover {
    background-image: none;
    color: var(--color-accent-hover);
  }

  .curtain-verse {
    max-width: 20rem;
    text-align: right;
    font-style: italic;
  }
</style>
