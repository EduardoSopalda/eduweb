---
interface Props {
  title: string;
  titleAccent?: string;
  subtitle?: string;
  phrase?: string;
  height?: 'full' | 'section';
  image?: string;
  imageAlt?: string;
  imageCredit?: string;
  video?: string;
  videoPoster?: string;
  layout?: 'center' | 'split';
}

const {
  title,
  titleAccent,
  subtitle,
  phrase,
  height = 'section',
  image,
  imageAlt = '',
  imageCredit,
  video,
  videoPoster,
  layout = 'center',
} = Astro.props;

const hasMedia = !!image || !!video;
const heightClass = height === 'full' ? 'hero--full' : 'hero--section';
const layoutClass = layout === 'split' ? 'hero--split' : '';
const phraseLines = phrase ? phrase.split(' / ') : [];
---

<section class:list={['hero', heightClass, layoutClass]} aria-label={titleAccent ? `${title} ${titleAccent}` : title}>
  {layout === 'split' ? (
    <div class="hero-split-grid">
      <div class="hero-split-media">
        {image && (
          <img
            class="hero-media hero-split-img"
            src={image}
            alt={imageAlt}
            loading="eager"
          />
        )}
        <div class="hero-vignette-split" aria-hidden="true"></div>
        {imageCredit && (
          <p class="hero-credit marginalia">
            <!-- PENDING: photographer credit -->
          </p>
        )}
      </div>
      <div class="hero-split-content">
        <div class="hero-split-text">
          {subtitle && <p class="hero-label hero-entrance hero-entrance-1">{subtitle}</p>}
          <h1 class="hero-title hero-entrance hero-entrance-2 glitch-name">
            {title}{titleAccent && <span class="hero-title-accent"> {titleAccent}</span>}
          </h1>
          {phrase && (
            <p class="hero-phrase hero-entrance hero-entrance-3">
              {phraseLines.length > 1
                ? phraseLines.map((line: string, i: number) => <>{i > 0 && <br />}{line}</>)
                : phrase}
            </p>
          )}
          <slot />
        </div>
      </div>
    </div>
  ) : (
    <>
      <div class="hero-bg">
        {video && (
          <video
            class="hero-media hero-video"
            autoplay
            muted
            loop
            playsinline
            preload="auto"
            poster={videoPoster}
            aria-hidden="true"
          >
            <source src={video} type="video/mp4" />
          </video>
        )}
        {image && !video && (
          <img
            class="hero-media"
            src={image}
            alt={imageAlt}
            loading={height === 'full' ? 'eager' : 'lazy'}
          />
        )}
        {!hasMedia && <div class="hero-empty" aria-hidden="true"></div>}
        <div class="hero-scrim" aria-hidden="true"></div>
        <div class="hero-vignette" aria-hidden="true"></div>
      </div>
      <div class="hero-content container">
        {subtitle && <p class="hero-label hero-entrance hero-entrance-1">{subtitle}</p>}
        <h1 class="hero-title hero-entrance hero-entrance-2 glitch-name">
          {title}{titleAccent && <span class="hero-title-accent"> {titleAccent}</span>}
        </h1>
        {phrase && (
          <p class="hero-phrase hero-entrance hero-entrance-3">
            {phraseLines.length > 1
              ? phraseLines.map((line: string, i: number) => <>{i > 0 && <br />}{line}</>)
              : phrase}
          </p>
        )}
        <slot />
      </div>
    </>
  )}
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero--full {
    min-height: 100vh;
    min-height: 100svh;
  }

  .hero--section {
    min-height: 55vh;
    min-height: 55svh;
  }

  @media (min-width: 48rem) {
    .hero--section {
      min-height: 60vh;
    }
  }

  /* ---- Centered layout (default) ---- */

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }

  @media (prefers-reduced-motion: no-preference) {
    html.chaos .hero-media {
      animation: kenburns 25s ease-in-out infinite alternate;
    }
  }

  @keyframes kenburns {
    0% { transform: scale(1); }
    100% { transform: scale(1.06); }
  }

  .hero-empty {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(ellipse at 30% 40%, #1a1520 0%, transparent 60%),
      radial-gradient(ellipse at 70% 60%, #181418 0%, transparent 60%),
      linear-gradient(165deg, #0f0e12 0%, #0B0B0D 40%, #100d14 100%);
  }

  .hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 10, 12, 0.3) 0%,
      rgba(10, 10, 12, 0.15) 40%,
      rgba(10, 10, 12, 0.5) 75%,
      rgba(10, 10, 12, 0.85) 100%
    );
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 40%, rgba(10, 10, 12, 0.6) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-block: var(--space-xl);
  }

  .hero--section .hero-content {
    text-align: center;
  }

  /* ---- Split layout (homepage) ---- */

  .hero--split {
    min-height: 100vh;
    min-height: 100svh;
    background-color: var(--color-base);
  }

  .hero-split-grid {
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    display: grid;
    grid-template-rows: 60vh auto;
  }

  @media (min-width: 48rem) {
    .hero-split-grid {
      grid-template-rows: none;
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 64rem) {
    .hero-split-grid {
      grid-template-columns: 55% 45%;
    }
  }

  .hero-split-media {
    position: relative;
    overflow: hidden;
  }

  /* Black sheer curtain — rises slowly to reveal Manuel */
  html.chaos .hero-split-media::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 4;
    background: linear-gradient(
      to bottom,
      rgba(10, 10, 12, 1) 0%,
      rgba(10, 10, 12, 0.98) 50%,
      rgba(10, 10, 12, 0.88) 80%,
      rgba(10, 10, 12, 0.4) 95%,
      transparent 100%
    );
    pointer-events: none;
    animation: curtainRise 7s cubic-bezier(0.16, 0.7, 0.3, 1) 0.8s forwards;
  }

  @keyframes curtainRise {
    0% { transform: translateY(0); }
    100% { transform: translateY(-105%); }
  }

  @media (prefers-reduced-motion: reduce) {
    html.chaos .hero-split-media::before {
      display: none;
    }
  }

  html:not(.chaos) .hero-split-media::before {
    display: none;
  }

  /* Gold heartbeat halo */
  html.chaos .hero-split-media::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(
      ellipse at 50% 35%,
      rgba(166, 135, 94, 0.5) 0%,
      rgba(139, 111, 71, 0.2) 30%,
      transparent 65%
    );
    mix-blend-mode: screen;
    pointer-events: none;
    animation: haloHeartbeat 1.8s ease-in-out infinite;
  }

  @keyframes haloHeartbeat {
    0%, 55%, 100% { opacity: 0.3; transform: scale(1); }
    15% { opacity: 1; transform: scale(1.15); }
    28% { opacity: 0.45; transform: scale(1.05); }
    42% { opacity: 0.85; transform: scale(1.1); }
  }

  @media (prefers-reduced-motion: reduce) {
    html.chaos .hero-split-media::after {
      animation: none;
      opacity: 0.5;
      transform: none;
    }
  }

  html:not(.chaos) .hero-split-media::after {
    display: none;
  }

  .hero-split-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
  }

  @media (prefers-reduced-motion: no-preference) {
    html.chaos .hero-split-img {
      animation: kenburns 30s ease-in-out infinite alternate;
    }
  }

  .hero-vignette-split {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      radial-gradient(ellipse at center, transparent 50%, rgba(10, 10, 12, 0.5) 100%),
      linear-gradient(to bottom, transparent 70%, rgba(10, 10, 12, 0.6) 100%);
  }

  @media (min-width: 48rem) {
    .hero-vignette-split {
      background:
        radial-gradient(ellipse at center, transparent 50%, rgba(10, 10, 12, 0.4) 100%),
        linear-gradient(to right, transparent 60%, rgba(10, 10, 12, 0.7) 100%);
    }
  }

  .hero-split-content {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg) var(--space-md);
  }

  @media (min-width: 48rem) {
    .hero-split-content {
      padding: var(--space-xl) var(--space-lg);
    }
  }

  .hero-split-text {
    max-width: 28rem;
  }

  .hero-credit {
    position: absolute;
    bottom: var(--space-sm);
    left: var(--space-sm);
    font-size: 0.65rem;
    opacity: 0.5;
  }

  /* ---- Shared typography ---- */

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent-interactive);
    margin-bottom: var(--space-sm);
  }

  .hero-title {
    font-size: clamp(3rem, 10vw, 8rem);
    letter-spacing: 0.02em;
    line-height: 1;
    margin-bottom: var(--space-xs);
    text-shadow: 0 2px 40px rgba(0, 0, 0, 0.5);
  }

  .hero--section .hero-title {
    font-size: clamp(2.5rem, 7vw, 5rem);
  }

  .hero--split .hero-title {
    font-size: clamp(2.5rem, 5vw, 5rem);
  }

  .hero-title-accent {
    color: var(--color-accent-interactive);
  }

  .hero-phrase {
    font-family: var(--font-body);
    font-size: clamp(0.8rem, 1.4vw, 0.95rem);
    font-style: italic;
    color: var(--color-text-secondary);
    max-width: 36rem;
    margin-left: auto;
    text-align: right;
    opacity: 0.7;
    line-height: 1.8;
    margin-top: var(--space-md);
  }

  .hero--split .hero-phrase {
    margin-left: 0;
    text-align: left;
    margin-top: var(--space-lg);
  }

  /* ---- Choreographed entrance ---- */

  @media (prefers-reduced-motion: no-preference) {
    html.chaos .hero--split {
      animation: theatreLightsUp 1.8s ease-out forwards;
    }

    html.chaos .hero-entrance {
      opacity: 0;
      transform: translateY(1.5rem);
      animation: heroReveal 0.8s ease-out forwards;
    }

    html.chaos .hero-entrance-1 { animation-delay: 0.8s; }
    html.chaos .hero-entrance-2 { animation-delay: 1.0s; }
    html.chaos .hero-entrance-3 { animation-delay: 1.3s; }

    html.chaos .hero--section .hero-entrance {
      animation-delay: 0s;
    }
    html.chaos .hero--section .hero-entrance-1 { animation-delay: 0.1s; }
    html.chaos .hero--section .hero-entrance-2 { animation-delay: 0.3s; }
    html.chaos .hero--section .hero-entrance-3 { animation-delay: 0.5s; }
  }

  @keyframes theatreLightsUp {
    0% { filter: brightness(0.1); }
    30% { filter: brightness(0.4); }
    100% { filter: brightness(1); }
  }

  @keyframes heroReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Calm mode + reduced-motion: immediate, no drama */
  html:not(.chaos) .hero-entrance,
  .hero-entrance {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-entrance,
    html.chaos .hero-entrance {
      opacity: 1;
      transform: none;
      animation: none;
    }

    html.chaos .hero--split {
      animation: none;
      filter: none;
    }
  }
</style>
