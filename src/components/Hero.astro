---
interface Props {
  title: string;
  subtitle?: string;
  phrase?: string;
  height?: 'full' | 'section';
  image?: string;
  imageAlt?: string;
  video?: string;
  videoPoster?: string;
}

const {
  title,
  subtitle,
  phrase,
  height = 'section',
  image,
  imageAlt = '',
  video,
  videoPoster,
} = Astro.props;

const hasMedia = !!image || !!video;
const heightClass = height === 'full' ? 'hero--full' : 'hero--section';
---

<section class:list={['hero', heightClass]} aria-label={title}>
  <div class="hero-bg">
    {video && (
      <video
        class="hero-media hero-video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        poster={videoPoster}
        aria-hidden="true"
      >
        <source src={video} type="video/mp4" />
      </video>
    )}
    {image && !video && (
      <img
        class="hero-media"
        src={image}
        alt={imageAlt}
        loading={height === 'full' ? 'eager' : 'lazy'}
      />
    )}
    {!hasMedia && <div class="hero-empty" aria-hidden="true"></div>}
    <div class="hero-scrim" aria-hidden="true"></div>
    <div class="hero-vignette" aria-hidden="true"></div>
  </div>
  <div class="hero-content container">
    {subtitle && <p class="hero-label hero-anim hero-anim-1">{subtitle}</p>}
    <h1 class="hero-title hero-anim hero-anim-2 glitch-name">{title}</h1>
    {phrase && <p class="hero-phrase hero-anim hero-anim-3">{phrase}</p>}
    <slot />
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero--full {
    min-height: 100vh;
    min-height: 100svh;
  }

  .hero--section {
    min-height: 55vh;
    min-height: 55svh;
  }

  @media (min-width: 48rem) {
    .hero--section {
      min-height: 60vh;
    }
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Ken Burns slow zoom */
  @media (prefers-reduced-motion: no-preference) {
    .hero-media {
      animation: kenburns 25s ease-in-out infinite alternate;
    }
  }

  @keyframes kenburns {
    0% { transform: scale(1); }
    100% { transform: scale(1.08); }
  }

  /* Empty state: gradient + grain texture */
  .hero-empty {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(ellipse at 30% 40%, #1a1520 0%, transparent 60%),
      radial-gradient(ellipse at 70% 60%, #181418 0%, transparent 60%),
      linear-gradient(165deg, #0f0e12 0%, #0B0B0D 40%, #100d14 100%);
  }

  /* Dark scrim overlay */
  .hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(11, 11, 13, 0.3) 0%,
      rgba(11, 11, 13, 0.15) 40%,
      rgba(11, 11, 13, 0.5) 75%,
      rgba(11, 11, 13, 0.85) 100%
    );
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 40%, rgba(11, 11, 13, 0.6) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding-block: var(--space-xl);
  }

  .hero-label {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent-interactive);
    margin-bottom: var(--space-sm);
  }

  .hero-title {
    font-size: clamp(3rem, 10vw, 8rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1;
    margin-bottom: var(--space-sm);
    text-shadow: 0 2px 40px rgba(0, 0, 0, 0.5);
  }

  .hero--section .hero-title {
    font-size: clamp(2.5rem, 7vw, 5rem);
  }

  .hero-phrase {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.5vw, 1.75rem);
    font-style: italic;
    color: var(--color-text);
    max-width: 36rem;
    margin-inline: auto;
    opacity: 0.9;
  }

  /* Staggered entrance animation */
  @media (prefers-reduced-motion: no-preference) {
    .hero-anim {
      opacity: 0;
      transform: translateY(1.5rem);
      animation: heroFadeIn 1s ease-out forwards;
    }

    .hero-anim-1 { animation-delay: 0.2s; }
    .hero-anim-2 { animation-delay: 0.5s; }
    .hero-anim-3 { animation-delay: 0.9s; }
  }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-anim {
      opacity: 1;
      transform: none;
    }
  }
</style>
