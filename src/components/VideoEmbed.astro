---
interface Props {
  provider: 'youtube' | 'vimeo';
  videoId: string;
  hash?: string;
  title: string;
  poster?: string;
  credit?: string;
  lang?: 'es' | 'en';
}

const { provider, videoId, hash, title, poster, credit, lang = 'es' } = Astro.props;

const embedUrl = provider === 'vimeo'
  ? `https://player.vimeo.com/video/${videoId}${hash ? `?h=${hash}` : ''}&autoplay=1&color=8B2020`
  : `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0`;

const thumbUrl = poster || (provider === 'youtube'
  ? `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`
  : undefined);

const playLabel = lang === 'es' ? `Reproducir ${title}` : `Play ${title}`;
---

<div class="video-facade" data-embed-url={embedUrl}>
  <div class="video-poster">
    {thumbUrl ? (
      <img src={thumbUrl} alt="" loading="lazy" class="video-poster-img" />
    ) : (
      <div class="empty-media empty-media--landscape" aria-hidden="true"></div>
    )}
    <div class="video-scrim" aria-hidden="true"></div>
  </div>
  <button class="video-play" type="button" aria-label={playLabel}>
    <svg class="video-play-icon" viewBox="0 0 48 48" fill="none" aria-hidden="true">
      <circle cx="24" cy="24" r="23" stroke="currentColor" stroke-width="2" opacity="0.6" />
      <polygon points="19,14 19,34 35,24" fill="currentColor" />
    </svg>
  </button>
  {credit && <p class="video-credit marginalia">{credit}</p>}
</div>

<div class="video-theater" hidden aria-label={title} role="dialog" aria-modal="true">
  <button class="theater-close" type="button" aria-label={lang === 'es' ? 'Cerrar vídeo' : 'Close video'}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <line x1="4" y1="4" x2="20" y2="20" /><line x1="20" y1="4" x2="4" y2="20" />
    </svg>
  </button>
  <div class="theater-embed"></div>
</div>

<script>
  function initVideoFacades() {
    document.querySelectorAll<HTMLElement>('.video-facade').forEach(facade => {
      const playBtn = facade.querySelector('.video-play') as HTMLButtonElement;
      const theater = facade.nextElementSibling as HTMLElement;
      if (!playBtn || !theater || !theater.classList.contains('video-theater')) return;

      const embedUrl = facade.dataset.embedUrl;
      const embedContainer = theater.querySelector('.theater-embed') as HTMLElement;
      const closeBtn = theater.querySelector('.theater-close') as HTMLButtonElement;

      function openTheater() {
        theater.hidden = false;
        document.body.style.overflow = 'hidden';
        embedContainer.innerHTML = `<iframe src="${embedUrl}" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen style="width:100%;height:100%;border:none;"></iframe>`;
        requestAnimationFrame(() => theater.classList.add('is-open'));
        closeBtn.focus();
      }

      function closeTheater() {
        theater.classList.remove('is-open');
        embedContainer.innerHTML = '';
        document.body.style.overflow = '';
        setTimeout(() => { theater.hidden = true; }, 400);
        playBtn.focus();
      }

      playBtn.addEventListener('click', openTheater);
      closeBtn.addEventListener('click', closeTheater);
      theater.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape') closeTheater();
      });
      theater.addEventListener('click', (e) => {
        if (e.target === theater) closeTheater();
      });
    });
  }

  initVideoFacades();
  document.addEventListener('astro:after-swap', initVideoFacades);
</script>

<style>
  .video-facade {
    position: relative;
    border-radius: 2px;
    overflow: hidden;
    cursor: pointer;
  }

  .video-poster {
    position: relative;
  }

  .video-poster-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .video-scrim {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(10, 10, 12, 0.2) 0%, rgba(10, 10, 12, 0.5) 100%);
  }

  .video-play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    transition: transform var(--transition-base);
  }

  .video-play:hover {
    transform: scale(1.1);
  }

  .video-play-icon {
    width: 4rem;
    height: 4rem;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.5));
  }

  .video-credit {
    position: absolute;
    bottom: var(--space-xs);
    right: var(--space-xs);
    font-size: 0.65rem;
  }

  /* Theater mode (sala a oscuras) */
  .video-theater {
    position: fixed;
    inset: 0;
    z-index: 200;
    background-color: rgba(0, 0, 0, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .video-theater.is-open {
    opacity: 1;
  }

  .theater-close {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    width: 2.5rem;
    height: 2.5rem;
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    cursor: pointer;
    color: #ECE7DE;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color var(--transition-fast), color var(--transition-fast);
    z-index: 10;
  }

  .theater-close:hover {
    border-color: var(--color-accent-interactive);
    color: var(--color-accent-interactive);
  }

  .theater-close svg {
    width: 1rem;
    height: 1rem;
  }

  .theater-embed {
    width: 90vw;
    max-width: 64rem;
    aspect-ratio: 16 / 9;
  }

  .theater-embed iframe {
    border-radius: 2px;
  }
</style>
