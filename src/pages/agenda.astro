---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
---

<Base
  title="Agenda"
  description="Funciones, giras y próximos proyectos de Manuel Monrò y La Tulpa."
>
  <Hero title="Agenda" subtitle="Funciones y gira" height="section" />

  <section class="section container">
    <article class="agenda-obra reveal">
      <div class="agenda-grid">
        <div class="agenda-image">
          <!-- PENDING FROM MANUEL: production photo -->
          <div class="empty-media empty-media--landscape" aria-hidden="true"></div>
        </div>
        <div class="agenda-info">
          <span class="label">En gira</span>
          <h2><a href="/obra/ensayo-sobre-nadie">Ensayo sobre nadie</a></h2>
          <p class="agenda-meta marginalia">2023 — Pieza breve de danza teatro</p>
        </div>
      </div>

      <div class="agenda-dates reveal reveal-delay-1">
        <h3 class="accent-underline">Funciones realizadas</h3>
        <ul class="agenda-list">
          <li>
            <span class="agenda-date">Sep 2023</span>
            <span class="agenda-venue">XVI Festival Internacional Escena Mobile, Teatro Alameda, Sevilla — <em>Estreno</em></span>
          </li>
          <li>
            <span class="agenda-date">2024</span>
            <span class="agenda-venue">Festival Kiada, Festival Internacional de Danza Accesible, Seúl, Corea — <em>Inauguración de la edición</em></span>
          </li>
          <li>
            <span class="agenda-date">2024</span>
            <span class="agenda-venue">Festival de Kirchheimbolanden, Alemania</span>
          </li>
          <li>
            <span class="agenda-date">May 2025</span>
            <span class="agenda-venue">Festival Madrid en Danza, BETA PUBLICA, XII Muestra Coreográfica Internacional, Teatros del Canal, Madrid</span>
          </li>
        </ul>
      </div>
      <!-- PENDING FROM MANUEL: upcoming performances, new projects, residencies -->
    </article>
  </section>

  <section class="section container">
    <div class="workshop-header reveal">
      <span class="marginalia marginalia--accent">Pedagogía</span>
      <h2 class="accent-underline">Talleres</h2>
    </div>
    <article class="workshop-card reveal reveal-delay-1">
      <div class="workshop-grid">
        <div class="workshop-image">
          <img src="/images/workshop-que-nadie-se-mueva.jpg" alt="Cartel del taller Que nadie se mueva — Mecánicas inverosímiles de Expresión Corporal" loading="lazy" class="img-full" />
        </div>
        <div class="workshop-info">
          <span class="label">Taller</span>
          <h3>Que nadie se mueva</h3>
          <p class="workshop-subtitle">&ldquo;Mecánicas inverosímiles de Expresión Corporal&rdquo;</p>
          <p class="workshop-meta marginalia">Manuel Monrò &amp; Susana Villegas</p>
          <dl class="workshop-details">
            <div>
              <dt class="marginalia">Fecha</dt>
              <dd>31 mayo / 1 junio</dd>
            </div>
            <div>
              <dt class="marginalia">Horario</dt>
              <dd>10:00 — 14:00 h</dd>
            </div>
            <div>
              <dt class="marginalia">Lugar</dt>
              <dd>La Vieja Imprenta 51, calle del Monte Oliveti 51, Madrid</dd>
            </div>
          </dl>
          <p class="workshop-contact">
            Info y reservas: <a href="mailto:cialatulpa@gmail.com">cialatulpa@gmail.com</a>
          </p>
        </div>
      </div>
    </article>
  </section>
</Base>

<style>
  .agenda-grid {
    display: grid;
    gap: var(--space-lg);
  }

  @media (min-width: 48rem) {
    .agenda-grid {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }
  }

  .agenda-image {
    overflow: hidden;
    border-radius: 2px;
  }

  .agenda-info .label {
    margin-bottom: var(--space-sm);
  }

  .agenda-info h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
  }

  .agenda-info h2 a {
    color: var(--color-text);
    background-image: none;
  }

  .agenda-info h2 a:hover {
    color: var(--color-accent-interactive);
  }

  .agenda-meta {
    margin-top: 0.25rem;
  }

  .agenda-dates {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-warm-grey);
  }

  .agenda-dates h3 {
    margin-bottom: var(--space-lg);
  }

  .agenda-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .agenda-list li {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: var(--space-sm);
    padding-block: var(--space-sm);
    border-bottom: 1px solid var(--color-warm-grey);
  }

  .agenda-date {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent-interactive);
    padding-top: 0.15em;
  }

  .agenda-venue {
    font-size: 0.95rem;
  }

  .workshop-header {
    margin-bottom: var(--space-md);
  }

  .workshop-header .marginalia {
    display: block;
    margin-bottom: var(--space-xs);
  }

  .workshop-card {
    background-color: var(--color-base-raised);
    border-radius: 2px;
    overflow: hidden;
  }

  .workshop-grid {
    display: grid;
    gap: var(--space-md);
  }

  @media (min-width: 48rem) {
    .workshop-grid {
      grid-template-columns: 1fr 1.2fr;
    }
  }

  .workshop-image img {
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: top;
  }

  .workshop-info {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    justify-content: center;
  }

  .workshop-info h3 {
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
  }

  .workshop-subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1rem;
    color: var(--color-text-secondary);
  }

  .workshop-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  .workshop-details dd {
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .workshop-contact {
    margin-top: var(--space-sm);
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }
</style>
