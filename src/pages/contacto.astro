---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
---

<Base
  title="Contacto"
  description="Contacto y contratación — Manuel Monrò y La Tulpa."
>
  <Hero title="Contacto" subtitle="Contratación y programación" height="section" />

  <section class="section container">
    <div class="contact-grid">
      <div class="prose reveal">
        <p>
          Para programar funciones, solicitar dossier o rider técnico, o cualquier consulta sobre la compañía y sus obras.
        </p>

        <div class="contact-block">
          <h2 class="contact-heading">Correo electrónico</h2>
          <p><a href="mailto:cialatulpa@gmail.com">cialatulpa@gmail.com</a></p>
        </div>

        <div class="contact-block">
          <h2 class="contact-heading">Redes</h2>
          <!-- PENDING FROM MANUEL: social media profiles (Instagram, Vimeo/YouTube) -->
          <p class="contact-placeholder-text">Próximamente</p>
        </div>

        <div class="contact-block">
          <h2 class="contact-heading">Dossier y rider técnico</h2>
          <!-- PENDING FROM MANUEL: PDF press kit and technical rider for download -->
          <p class="contact-placeholder-text">Disponible bajo petición</p>
        </div>
      </div>

      <div class="contact-aside reveal reveal-delay-1">
        <div class="contact-note">
          <h3>Para programadores y festivales</h3>
          <p>
            Si desea programar <em>Ensayo sobre nadie</em> u otras piezas de La Tulpa en su espacio o festival, contacte directamente por correo electrónico. Enviamos dossier completo, ficha técnica y rider bajo petición.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-grid {
    display: grid;
    gap: var(--space-lg);
  }

  @media (min-width: 48rem) {
    .contact-grid {
      grid-template-columns: 1.5fr 1fr;
    }
  }

  .contact-block {
    margin-top: var(--space-lg);
  }

  .contact-heading {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xs);
  }

  .contact-placeholder-text {
    color: var(--color-text-secondary);
    font-style: italic;
    font-size: 0.95rem;
  }

  .contact-note {
    background-color: var(--color-base-raised);
    border-left: 4px solid var(--color-accent-solid);
    padding: var(--space-md);
    border-radius: 2px;
  }

  .contact-note h3 {
    font-size: 1.125rem;
    margin-bottom: var(--space-xs);
  }

  .contact-note p {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
  }
</style>
