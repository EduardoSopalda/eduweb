---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
---

<Base
  title="Contact"
  description="Contact and booking — Manuel Monró and La Tulpa."
>
  <Hero title="Contact" subtitle="Booking and programming" height="section" />

  <section class="section container">
    <div class="contact-grid">
      <div class="prose reveal">
        <p>
          To book performances, request a press kit or technical rider, or for any enquiry about the company and its works.
        </p>

        <div class="contact-block">
          <h2 class="contact-heading">Email</h2>
          <!-- PENDING FROM MANUEL: contact email address -->
          <p class="contact-placeholder-text">Coming soon</p>
        </div>

        <div class="contact-block">
          <h2 class="contact-heading">Social media</h2>
          <!-- PENDING FROM MANUEL: social media profiles (Instagram, Vimeo/YouTube) -->
          <p class="contact-placeholder-text">Coming soon</p>
        </div>

        <div class="contact-block">
          <h2 class="contact-heading">Press kit and technical rider</h2>
          <!-- PENDING FROM MANUEL: PDF press kit and technical rider for download -->
          <p class="contact-placeholder-text">Available on request</p>
        </div>
      </div>

      <div class="contact-aside reveal reveal-delay-1">
        <div class="contact-note">
          <h3>For programmers and festivals</h3>
          <p>
            If you would like to programme <em>Ensayo sobre nadie</em> or other La Tulpa pieces at your venue or festival, please contact us directly by email. We send a full press kit, technical sheet and rider on request.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-grid {
    display: grid;
    gap: var(--space-lg);
  }

  @media (min-width: 48rem) {
    .contact-grid {
      grid-template-columns: 1.5fr 1fr;
    }
  }

  .contact-block {
    margin-top: var(--space-lg);
  }

  .contact-heading {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xs);
  }

  .contact-placeholder-text {
    color: var(--color-text-secondary);
    font-style: italic;
    font-size: 0.95rem;
  }

  .contact-note {
    background-color: var(--color-base-raised);
    border-left: 4px solid var(--color-accent-solid);
    padding: var(--space-md);
    border-radius: 2px;
  }

  .contact-note h3 {
    font-size: 1.125rem;
    margin-bottom: var(--space-xs);
  }

  .contact-note p {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
  }
</style>
