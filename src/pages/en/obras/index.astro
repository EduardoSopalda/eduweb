---
import Base from '../../../layouts/Base.astro';
import ImagePlaceholder from '../../../components/ImagePlaceholder.astro';
import { getCollection } from 'astro:content';

const obras = await getCollection('obras');
const obrasSorted = obras.sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Works"
  description="Works produced by La Tulpa, Manuel Monró's dance company."
>
  <section class="section container">
    <span class="accent-line"></span>
    <h1>Works produced</h1>
    <div class="obras-list">
      {obrasSorted.map((obra) => (
        <article class="obra-card reveal">
          <a href={`/en/obras/${obra.data.slug}`} class="obra-card-link">
            <ImagePlaceholder
              aspect="16/9"
              label={`[Photograph of ${obra.data.title} — pending from Manuel]`}
            />
            <div class="obra-card-info">
              <h2>{obra.data.title}</h2>
              <p class="obra-card-meta">
                {obra.data.year} — {obra.data.type}
              </p>
              {obra.data.touring && (
                <span class="obra-touring-badge">On tour</span>
              )}
            </div>
          </a>
        </article>
      ))}
    </div>
    <div class="placeholder reveal" style="margin-top: var(--space-lg);">
      [Pending from Manuel: other works produced after Ensayo sobre nadie, if any.]
    </div>
  </section>
</Base>

<style>
  .obras-list {
    display: grid;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  @media (min-width: 48rem) {
    .obras-list {
      grid-template-columns: repeat(auto-fill, minmax(28rem, 1fr));
    }
  }

  .obra-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .obra-card-link:hover h2 {
    color: var(--color-accent-interactive);
  }

  .obra-card-info {
    padding-top: var(--space-sm);
  }

  .obra-card-info h2 {
    font-size: 1.5rem;
    transition: color var(--transition-fast);
  }

  .obra-card-meta {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    margin-top: 0.25rem;
  }

  .obra-touring-badge {
    display: inline-block;
    margin-top: var(--space-xs);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-interactive);
    border: 1px solid var(--color-accent);
    padding: 0.2em 0.6em;
    border-radius: 2px;
  }
</style>
