---
import Base from '../../../layouts/Base.astro';
import Hero from '../../../components/Hero.astro';
import { getCollection } from 'astro:content';

const obras = await getCollection('obras');
const obrasSorted = obras.sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Works"
  description="Works produced by La Tulpa, Manuel Monró's dance company."
>
  <Hero title="Works" subtitle="Archive" height="section" />

  <section class="section container">
    <div class="obras-list">
      {obrasSorted.map((obra, i) => (
        <article class:list={['obra-card', 'reveal', `reveal-delay-${i + 1}`]}>
          <a href={`/en/obras/${obra.data.slug}`} class="obra-card-link">
            <div class="obra-card-image">
              <!-- ASSET: Replace with production photo -->
              <div class="obra-card-empty" aria-hidden="true"></div>
              <div class="obra-card-overlay">
                <span class="label">{obra.data.year}</span>
              </div>
            </div>
            <div class="obra-card-info">
              <h2>{obra.data.title}</h2>
              <p class="obra-card-meta">{obra.data.type}</p>
              {obra.data.touring && (
                <span class="label label--outline">On tour</span>
              )}
            </div>
          </a>
        </article>
      ))}
    </div>
    <!-- PENDING FROM MANUEL: other works produced after Ensayo sobre nadie, if any -->
  </section>
</Base>

<style>
  .obras-list {
    display: grid;
    gap: var(--space-lg);
  }

  @media (min-width: 48rem) {
    .obras-list {
      grid-template-columns: repeat(auto-fill, minmax(28rem, 1fr));
    }
  }

  .obra-card-link {
    display: block;
    color: inherit;
    background-image: none;
    border-radius: 2px;
    overflow: hidden;
    background-color: var(--color-base-raised);
    transition: background-color var(--transition-fast);
  }

  .obra-card-link:hover {
    background-color: var(--color-base-surface);
    background-image: none;
  }

  .obra-card-link:hover h2 {
    color: var(--color-accent-interactive);
  }

  .obra-card-image {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .obra-card-empty {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(ellipse at 40% 50%, #1a1520 0%, transparent 60%),
      linear-gradient(165deg, #0f0e12, #0B0B0D 50%, #100d14);
    transition: transform 0.8s ease-out;
  }

  @media (prefers-reduced-motion: no-preference) {
    .obra-card-link:hover .obra-card-empty {
      transform: scale(1.05);
    }
  }

  .obra-card-overlay {
    position: absolute;
    bottom: var(--space-sm);
    left: var(--space-sm);
  }

  .obra-card-info {
    padding: var(--space-md);
  }

  .obra-card-info h2 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
    transition: color var(--transition-fast);
  }

  .obra-card-meta {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    margin-bottom: var(--space-xs);
  }
</style>
