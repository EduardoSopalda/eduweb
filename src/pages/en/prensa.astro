---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
---

<Base
  title="Press"
  description="Reviews and press coverage of La Tulpa and the works of Manuel Monró."
>
  <Hero title="Press" height="section" />

  <section class="section container">
    <div class="prose reveal">
      <p>
        Selected excerpts from reviews and media coverage of La Tulpa's work.
      </p>
    </div>

    <div class="press-list">
      <article class="press-item reveal reveal-delay-1">
        <blockquote>
          <p>
            &laquo;The aesthetic may seem sinister, but these beings are harmless.&raquo;
          </p>
        </blockquote>
        <p class="press-source">
          Review of <em>Ensayo sobre nadie</em>, following its premiere at the 16th Escena Mobile Festival, Seville, 2023.
        </p>
        <!-- PENDING: author and publication of the review, for proper attribution -->
        <!-- PENDING: link to original article when available -->
      </article>
    </div>
    <!-- PENDING: additional reviews and press coverage -->
  </section>
</Base>

<style>
  .press-list {
    margin-top: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .press-item blockquote {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    border-left: 4px solid var(--color-accent-solid);
    padding-left: var(--space-md);
    color: var(--color-text);
    font-style: italic;
    margin-bottom: var(--space-md);
    line-height: 1.4;
  }

  .press-source {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    padding-left: calc(var(--space-md) + 4px);
  }
</style>
