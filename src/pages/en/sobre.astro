---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
---

<Base
  title="Manuel Monró"
  description="Manuel Monró — choreographer, performer and artistic director of La Tulpa. Contemporary dance, dance theatre and inclusive creation from Seville and Barcelona."
>
  <Hero
    title="Manuel Monró"
    subtitle="Director · Choreographer · Playwright · Performer"
    height="section"
  />

  <section class="section container" aria-labelledby="about-heading">
    <div class="about-grid">
      <div class="about-main">
        <h2 id="about-heading" class="sr-only">About Manuel Monró</h2>

        <div class="about-portrait reveal">
          <!-- PENDING FROM MANUEL: portrait photo -->
          <div class="empty-media empty-media--portrait" aria-hidden="true"></div>
        </div>

        <div class="prose about-text reveal reveal-delay-1">
          <p class="about-role">Director. Choreographer. Playwright. Performer.</p>
          <p>
            Manuel Monró works between Barcelona and Seville. His language moves in the territory of contemporary dance, dance theatre and inclusive creation. He does not seek to illustrate difference. He works from it.
          </p>
          <p>
            Linked to the inclusive dance circuit, he collaborates closely with Compañía Danza Mobile in Seville. In 2023, following his participation in the 16th Escena Mobile International Festival of Art and Diversity, he founded <a href="/en/obra/la-tulpa">La Tulpa</a>.
          </p>
          <!-- PENDING FROM MANUEL: training, detailed career, artist statement -->
        </div>

        <div class="about-language reveal reveal-delay-2">
          <h2 class="accent-underline">Language</h2>
          <div class="prose">
            <p>
              What happens on stage is born from difference: from distinct bodies that meet, listen, transform one another. Simple, precise movement. A chiaroscuro aesthetic that seeks the half-light to look more carefully.
            </p>
            <p>
              Each piece is an investigation. Each performance, an act of presence.
            </p>
          </div>
        </div>

        <div class="about-international reveal reveal-delay-3">
          <h2 class="accent-underline">International presence</h2>
          <div class="prose">
            <p>
              He has toured Spain, South Korea and Germany. He works in close relationship with Compañía Danza Mobile from Seville and with the international circuit of accessible dance.
            </p>
          </div>
          <ul class="about-tour-list">
            <li>
              <span class="marginalia">2023</span>
              <span>16th Escena Mobile International Festival, Seville</span>
            </li>
            <li>
              <span class="marginalia">2024</span>
              <span>Kiada Festival, Seoul International Accessible Dance Festival</span>
            </li>
            <li>
              <span class="marginalia">2024</span>
              <span>Kirchheimbolanden Festival, Germany</span>
            </li>
            <li>
              <span class="marginalia">2025</span>
              <span>Madrid en Danza, Teatros del Canal, Madrid</span>
            </li>
          </ul>
        </div>
      </div>

      <aside class="about-aside">
        <div class="about-meta reveal reveal-delay-1">
          <dl class="about-facts">
            <div class="about-fact">
              <dt class="marginalia">Company</dt>
              <dd><a href="/en/obra/la-tulpa">La Tulpa</a></dd>
            </div>
            <div class="about-fact">
              <dt class="marginalia">Base</dt>
              <dd>Barcelona / Seville</dd>
            </div>
            <div class="about-fact">
              <dt class="marginalia">Founded</dt>
              <dd>2023, Seville</dd>
            </div>
            <div class="about-fact">
              <dt class="marginalia">Collaboration</dt>
              <dd>Danza Mobile</dd>
            </div>
            <div class="about-fact">
              <dt class="marginalia">Disciplines</dt>
              <dd>Contemporary dance, dance theatre, inclusive creation</dd>
            </div>
            <div class="about-fact">
              <dt class="marginalia">International</dt>
              <dd>Spain, South Korea, Germany</dd>
            </div>
          </dl>
        </div>

        <div class="about-quote reveal reveal-delay-2">
          <blockquote>
            <p>A thought made body.</p>
          </blockquote>
          <p class="marginalia">— On the name <em>La Tulpa</em></p>
        </div>

        <div class="about-cta reveal reveal-delay-3">
          <a href="/en/obra" class="cta-link">See work &rarr;</a>
          <a href="/en/agenda" class="cta-link">Schedule &rarr;</a>
        </div>
      </aside>
    </div>
  </section>
</Base>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .about-grid {
    display: grid;
    gap: var(--space-lg);
  }

  @media (min-width: 48rem) {
    .about-grid {
      grid-template-columns: 2fr 1fr;
      align-items: start;
    }
  }

  .about-portrait {
    max-width: 20rem;
    margin-bottom: var(--space-lg);
  }

  html.chaos .about-portrait {
    transform: rotate(calc(var(--chaos-rotate) * -0.7));
  }

  html:not(.chaos) .about-portrait {
    transform: none;
  }

  .about-role {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-accent-interactive);
    margin-bottom: var(--space-md);
    letter-spacing: 0.02em;
  }

  .about-text p {
    margin-bottom: var(--space-sm);
  }

  .about-language,
  .about-international {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-warm-grey);
  }

  .about-language h2,
  .about-international h2 {
    margin-bottom: var(--space-md);
  }

  .about-tour-list {
    list-style: none;
    padding: 0;
    margin-top: var(--space-md);
  }

  .about-tour-list li {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: var(--space-sm);
    padding-block: var(--space-xs);
    border-bottom: 1px solid var(--color-warm-grey);
    font-size: 0.95rem;
  }

  .about-meta {
    background-color: var(--color-base-raised);
    padding: var(--space-md);
    border-radius: 2px;
    border-left: 3px solid var(--color-accent-solid);
  }

  .about-facts {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .about-fact dt {
    margin-bottom: 0.2rem;
  }

  .about-fact dd {
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .about-quote {
    margin-top: var(--space-lg);
  }

  .about-quote blockquote {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-style: italic;
    color: var(--color-text);
    border-left: 3px solid var(--color-accent-solid);
    padding-left: var(--space-md);
    margin-bottom: var(--space-xs);
  }

  .about-cta {
    margin-top: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .cta-link {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-accent-interactive);
    background-image: none;
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: 0.15rem;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .cta-link:hover {
    color: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
  }
</style>
