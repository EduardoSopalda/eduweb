---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import VeiledFaces from '../components/VeiledFaces.astro';
import { getCollection } from 'astro:content';

const obras = (await getCollection('obras')).sort((a, b) => (b.data.order || 0) - (a.data.order || 0));
const featured = obras.find((o) => o.data.touring) || obras[0];
---

<Base
  title="Inicio"
  description="Manuel Monrò — director, coreógrafo, dramaturgo, pedagogo e intérprete. Danza contemporánea, danza teatro y creación inclusiva."
>
  <Hero
    title="Manuel"
    titleAccent="Monrò"
    subtitle="Dirección · Coreografía · Dramaturgia · Pedagogía · Interpretación"
    phrase="Cuando el reflejo mira la sombra, / nadie aquí respira."
    height="full"
    layout="split"
    image="/images/manuel-monro-hero.jpg"
    imageAlt="Manuel Monrò en movimiento, cuerpo en torsión con falda de tul translúcida, fotografía en blanco y negro"
    imageCredit="pending"
  />

  <!-- Second punch: veiled faces -->
  <VeiledFaces lang="es" />

  <!-- Dramatic interstitial -->
  <section class="interstitial" aria-hidden="true">
    <div class="interstitial-inner">
      <p class="interstitial-text reveal">
        Casi nadie se pregunta si es más real<br />
        lo que se puede ver, lo que se puede oír,<br />
        <span class="interstitial-accent">o lo que se contiene.</span>
      </p>
      <span class="interstitial-source reveal reveal-delay-1 marginalia">— Ensayo sobre nadie</span>
    </div>
  </section>

  <!-- Identity -->
  <section class="section container" aria-labelledby="home-identity">
    <div class="identity reveal">
      <h2 id="home-identity" class="identity-statement">
        Director, coreógrafo, dramaturgo, pedagogo e intérprete. Trabaja entre Barcelona y Sevilla en el cruce entre danza contemporánea, danza teatro y creación inclusiva.
      </h2>
    </div>

    <div class="disciplines reveal reveal-delay-1">
      <span class="discipline-tag">Dirección</span>
      <span class="discipline-tag">Coreografía</span>
      <span class="discipline-tag">Dramaturgia</span>
      <span class="discipline-tag">Pedagogía</span>
      <span class="discipline-tag">Interpretación</span>
      <span class="discipline-tag">Poesía</span>
      <span class="discipline-tag">Pintura</span>
    </div>
  </section>

  <!-- Approach -->
  <section class="section container home-approach" aria-labelledby="home-approach-title">
    <h2 id="home-approach-title" class="sr-only">Lenguaje</h2>
    <div class="approach-statement reveal">
      <p class="approach-text-large">
        Lo que ocurre en escena nace de la diferencia: de cuerpos distintos que se encuentran, se escuchan, se transforman.
      </p>
    </div>
    <div class="approach-grid reveal reveal-delay-1">
      <div class="approach-main">
        <p class="approach-text">
          Movimiento simple y preciso. Una estética de claroscuro que busca la penumbra para mirar con más cuidado.
        </p>
        <p class="approach-text approach-text--emphasis">
          Cada pieza es una investigación. Cada función, un acto de presencia.
        </p>
      </div>
      <aside class="approach-aside chaos-shift">
        <div class="approach-line" aria-hidden="true"></div>
      </aside>
    </div>
  </section>

  <!-- Featured work -->
  {featured && (
    <section class="section home-featured" aria-labelledby="home-work-title">
      <div class="featured-media reveal">
        {featured.data.image
          ? <img class="featured-img" src={featured.data.image} alt={featured.data.title} loading="lazy" />
          : <div class="empty-media empty-media--landscape" aria-hidden="true"></div>
        }
        <div class="featured-scrim" aria-hidden="true"></div>
      </div>
      <div class="featured-content container reveal reveal-delay-1">
        {featured.data.touring && <span class="label">En gira</span>}
        <span class="marginalia">En escena</span>
        <h2 id="home-work-title">{featured.data.title}</h2>
        <p class="featured-meta marginalia">
          {featured.data.year} — {featured.data.type}
        </p>
        <p class="featured-desc">
          Pieza breve de danza teatro. Coreografía de {featured.data.choreography}.
        </p>
        <a href={`/obra/${featured.data.slug}`} class="cta-link">Descubrir &rarr;</a>
      </div>
    </section>
  )}

  <!-- International presence -->
  <section class="section container home-presence" aria-labelledby="home-presence-title">
    <h2 id="home-presence-title" class="accent-underline reveal">Presencia internacional</h2>
    <div class="presence-grid reveal reveal-delay-1">
      <div class="presence-item">
        <span class="presence-year marginalia">2023</span>
        <span class="presence-place">Sevilla</span>
        <span class="presence-detail">Festival Escena Mobile — Estreno</span>
      </div>
      <div class="presence-item">
        <span class="presence-year marginalia">2024</span>
        <span class="presence-place">Seúl</span>
        <span class="presence-detail">Festival Kiada — Inauguración</span>
      </div>
      <div class="presence-item">
        <span class="presence-year marginalia">2024</span>
        <span class="presence-place">Alemania</span>
        <span class="presence-detail">Festival de Kirchheimbolanden</span>
      </div>
      <div class="presence-item">
        <span class="presence-year marginalia">2025</span>
        <span class="presence-place">Madrid</span>
        <span class="presence-detail">Madrid en Danza, Teatros del Canal</span>
      </div>
      <div class="presence-item">
        <span class="presence-year marginalia">2026</span>
        <span class="presence-place">Arles</span>
        <span class="presence-detail">Théâtre Antique d'Arles</span>
      </div>
    </div>
  </section>

  <!-- La Tulpa -->
  <section class="section container home-tulpa" aria-labelledby="home-tulpa-title">
    <div class="tulpa-grid reveal">
      <div class="tulpa-main">
        <span class="marginalia">Compañía</span>
        <h2 id="home-tulpa-title" class="accent-underline">La Tulpa</h2>
        <p>
          En la tradición tibetana, una tulpa es un ser que cobra forma a través del pensamiento y la voluntad. Un pensamiento que se hace cuerpo. Fundada en 2023 en colaboración con Danza Mobile, Sevilla.
        </p>
        <a href="/obra/la-tulpa" class="cta-link">Conocer La Tulpa &rarr;</a>
      </div>
      <div class="tulpa-aside">
        <img class="tulpa-logo chaos-tilt" src="/images/la-tulpa-logo.jpg" alt="Logo de La Tulpa" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="section container home-cta" aria-labelledby="home-contact">
    <div class="reveal">
      <span class="marginalia">Contratación y programación</span>
      <h2 id="home-contact" class="accent-underline">Contacto</h2>
      <p class="cta-text">
        Para programar funciones, solicitar dossier o rider técnico, o cualquier consulta sobre Manuel Monrò y La Tulpa.
      </p>
      <a href="mailto:cialatulpa@gmail.com" class="cta-link cta-link--large">cialatulpa@gmail.com</a>
    </div>
  </section>
</Base>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Dramatic interstitial */
  .interstitial {
    position: relative;
    background-color: #000;
    padding-block: var(--space-xl);
    overflow: hidden;
  }

  @media (min-width: 48rem) {
    .interstitial {
      padding-block: var(--space-2xl);
    }
  }

  .interstitial::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 4rem;
    background: linear-gradient(to bottom, transparent, var(--color-accent-solid));
  }

  .interstitial-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-md);
    text-align: center;
  }

  .interstitial-text {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 3rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.5;
    color: rgba(236, 231, 222, 0.85);
    letter-spacing: 0.01em;
  }

  .interstitial-accent {
    color: var(--color-accent-interactive);
  }

  .interstitial-source {
    display: block;
    margin-top: var(--space-md);
    font-style: italic;
  }

  /* Identity */
  .identity-statement {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    font-weight: 400;
    line-height: 1.35;
    color: var(--color-text);
    max-width: var(--content-width);
    margin-bottom: var(--space-lg);
  }

  .disciplines {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .discipline-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-warm-grey);
    padding: 0.4em 1em;
    border-radius: 2px;
  }

  /* Approach */
  .home-approach {
    border-top: 3px solid var(--color-accent-solid);
  }

  .approach-statement {
    margin-bottom: var(--space-lg);
  }

  .approach-text-large {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.35;
    color: var(--color-text);
    max-width: 42rem;
  }

  .approach-grid {
    display: grid;
    gap: var(--space-lg);
  }

  @media (min-width: 48rem) {
    .approach-grid {
      grid-template-columns: 1.5fr 1fr;
      align-items: start;
    }
  }

  .approach-text {
    font-size: 1.125rem;
    line-height: 1.7;
    max-width: var(--content-width);
    margin-bottom: var(--space-sm);
  }

  .approach-text--emphasis {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.25rem;
    color: var(--color-text);
    margin-top: var(--space-md);
  }

  .approach-line {
    width: 3px;
    height: 6rem;
    background: linear-gradient(to bottom, var(--color-accent-solid), transparent);
    margin-left: auto;
  }

  @media (min-width: 48rem) {
    .approach-aside {
      padding-top: var(--space-md);
    }
  }

  /* Featured work — cinematic full-bleed */
  .home-featured {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .featured-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }

  .featured-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(10, 10, 12, 0.95) 0%,
      rgba(10, 10, 12, 0.6) 40%,
      rgba(10, 10, 12, 0.2) 70%,
      transparent 100%
    );
  }

  html:not(.chaos) .featured-scrim {
    background: linear-gradient(
      to top,
      rgba(245, 242, 237, 0.95) 0%,
      rgba(245, 242, 237, 0.6) 40%,
      rgba(245, 242, 237, 0.2) 70%,
      transparent 100%
    );
  }

  .featured-content {
    position: relative;
    z-index: 1;
    padding-block: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .featured-content .marginalia {
    display: block;
  }

  .featured-content h2 {
    font-size: clamp(2.5rem, 6vw, 5rem);
    margin-bottom: 0;
    line-height: 1.1;
  }

  .featured-meta {
    font-size: 0.8rem;
  }

  .featured-desc {
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 28rem;
  }

  .featured-content .label {
    align-self: flex-start;
  }

  /* International presence */
  .home-presence {
    border-top: 3px solid var(--color-accent-solid);
  }

  .presence-grid {
    display: grid;
    gap: 0;
    margin-top: var(--space-md);
  }

  @media (min-width: 48rem) {
    .presence-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 64rem) {
    .presence-grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .presence-item {
    padding: var(--space-md);
    border-bottom: 1px solid var(--color-warm-grey);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  @media (min-width: 48rem) {
    .presence-item {
      border-bottom: none;
      border-right: 1px solid var(--color-warm-grey);
    }

    .presence-item:last-child {
      border-right: none;
    }
  }

  .presence-place {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .presence-detail {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  /* La Tulpa */
  .home-tulpa {
    border-top: 3px solid var(--color-accent-solid);
  }

  .tulpa-grid {
    display: grid;
    gap: var(--space-lg);
    align-items: center;
  }

  @media (min-width: 48rem) {
    .tulpa-grid {
      grid-template-columns: 1.5fr 1fr;
    }
  }

  .tulpa-main .marginalia {
    display: block;
    margin-bottom: var(--space-xs);
  }

  .tulpa-main p {
    margin-top: var(--space-sm);
    max-width: 36rem;
    color: var(--color-text-secondary);
  }

  .tulpa-logo {
    max-width: 14rem;
    margin-left: auto;
    border-radius: 2px;
  }

  /* Contact CTA */
  .home-cta {
    text-align: center;
    border-top: 3px solid var(--color-accent-solid);
  }

  .home-cta .marginalia {
    display: block;
    margin-bottom: var(--space-xs);
  }

  .cta-text {
    max-width: 32rem;
    margin-inline: auto;
    margin-top: var(--space-sm);
    color: var(--color-text-secondary);
  }

  .cta-link {
    display: inline-block;
    margin-top: var(--space-md);
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-accent-interactive);
    background-image: none;
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: 0.2rem;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .cta-link:hover {
    color: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
  }

  .cta-link--large {
    font-size: 1.35rem;
    border-bottom-width: 3px;
  }
</style>
