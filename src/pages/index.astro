---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import VeiledFaces from '../components/VeiledFaces.astro';
import { getCollection } from 'astro:content';

const obras = (await getCollection('obras')).sort((a, b) => (b.data.order || 0) - (a.data.order || 0));
const featured = obras.find((o) => o.data.touring) || obras[0];
---

<Base
  title="Inicio"
  description="Manuel Monrò — director, coreógrafo, dramaturgo, pedagogo e intérprete. Danza contemporánea, danza teatro y creación inclusiva."
>
  <Hero
    title="Manuel"
    titleAccent="Monrò"
    subtitle="Dirección · Coreografía · Dramaturgia · Pedagogía · Interpretación"
    phrase="Cuando el reflejo mira la sombra, / nadie aquí respira."
    height="full"
    layout="split"
    image="/images/manuel-monro-hero.jpg"
    imageAlt="Manuel Monrò en movimiento, cuerpo en torsión con falda de tul translúcida, fotografía en blanco y negro"
    imageCredit="pending"
  />

  <!-- Second punch: veiled faces -->
  <VeiledFaces lang="es" />

  <!-- Dramatic interstitial -->
  <section class="interstitial" aria-hidden="true">
    <div class="interstitial-inner">
      <p class="interstitial-text reveal">
        Casi nadie se pregunta si es más real<br />
        lo que se puede ver, lo que se puede oír,<br />
        <span class="interstitial-accent">o lo que se contiene.</span>
      </p>
      <span class="interstitial-source reveal reveal-delay-1 marginalia">— Ensayo sobre nadie</span>
    </div>
  </section>

  <!-- Identity -->
  <section class="section container" aria-labelledby="home-identity">
    <div class="identity reveal">
      <h2 id="home-identity" class="identity-statement">
        Director, coreógrafo, dramaturgo, pedagogo e intérprete. Trabaja entre Barcelona y Sevilla en el cruce entre danza contemporánea, danza teatro y creación inclusiva.
      </h2>
    </div>

    <div class="disciplines reveal reveal-delay-1">
      <span class="discipline-tag">Dirección</span>
      <span class="discipline-tag">Coreografía</span>
      <span class="discipline-tag">Dramaturgia</span>
      <span class="discipline-tag">Pedagogía</span>
      <span class="discipline-tag">Interpretación</span>
      <span class="discipline-tag">Poesía</span>
      <span class="discipline-tag">Pintura</span>
    </div>
  </section>

  <!-- Approach -->
  <section class="section container home-approach" aria-labelledby="home-approach-title">
    <div class="approach-grid">
      <div class="approach-main reveal">
        <h2 id="home-approach-title" class="sr-only">Lenguaje</h2>
        <p class="approach-text">
          Lo que ocurre en escena nace de la diferencia: de cuerpos distintos que se encuentran, se escuchan, se transforman. Movimiento simple y preciso. Una estética de claroscuro que busca la penumbra para mirar con más cuidado.
        </p>
        <p class="approach-text approach-text--emphasis">
          Cada pieza es una investigación. Cada función, un acto de presencia.
        </p>
      </div>
      <aside class="approach-aside reveal reveal-delay-1 chaos-shift">
        <blockquote class="approach-quote">
          <p>&ldquo;Casi nadie se pregunta si es más real lo que se puede ver, lo que se puede oír, o lo que se contiene.&rdquo;</p>
        </blockquote>
        <p class="marginalia">— <em>Ensayo sobre nadie</em></p>
      </aside>
    </div>
  </section>

  <!-- Featured work -->
  {featured && (
    <section class="section container" aria-labelledby="home-work-title">
      <div class="work-header reveal">
        <span class="marginalia">En escena</span>
        <h2 id="home-work-title" class="accent-underline">{featured.data.title}</h2>
      </div>
      <div class="home-work-card reveal reveal-delay-1">
        <div class="work-card-media">
          {featured.data.image
            ? <img class="work-card-img" src={featured.data.image} alt={featured.data.title} loading="lazy" />
            : <div class="empty-media empty-media--landscape" aria-hidden="true"></div>
          }
        </div>
        <div class="work-card-info">
          {featured.data.touring && <span class="label">En gira</span>}
          <h3>
            <a href={`/obra/${featured.data.slug}`}>{featured.data.title}</a>
          </h3>
          <p class="work-card-meta marginalia">
            {featured.data.year} — {featured.data.type}
          </p>
          <p class="work-card-desc">
            Pieza breve de danza teatro. Coreografía de {featured.data.choreography}.
          </p>
          <a href="/obra" class="work-card-link">Ver obra completa &rarr;</a>
        </div>
      </div>
    </section>
  )}

  <!-- Performance counter -->
  <section class="counter" aria-label="Trayectoria en cifras">
    <div class="counter-inner container reveal">
      <div class="counter-item">
        <span class="counter-number">5</span>
        <span class="counter-label">países</span>
      </div>
      <div class="counter-divider" aria-hidden="true"></div>
      <div class="counter-item">
        <span class="counter-number">8</span>
        <span class="counter-label">festivales</span>
      </div>
      <div class="counter-divider" aria-hidden="true"></div>
      <div class="counter-item">
        <span class="counter-number">3</span>
        <span class="counter-label">creaciones</span>
      </div>
      <div class="counter-divider" aria-hidden="true"></div>
      <div class="counter-item counter-item--accent">
        <span class="counter-status">En gira</span>
      </div>
    </div>
  </section>

  <!-- International presence -->
  <section class="section container home-presence" aria-labelledby="home-presence-title">
    <h2 id="home-presence-title" class="accent-underline reveal">Presencia internacional</h2>
    <div class="presence-grid reveal reveal-delay-1">
      <div class="presence-item">
        <span class="presence-year marginalia">2023</span>
        <span class="presence-place">Sevilla</span>
        <span class="presence-detail">Festival Escena Mobile — Estreno</span>
      </div>
      <div class="presence-item">
        <span class="presence-year marginalia">2024</span>
        <span class="presence-place">Seúl</span>
        <span class="presence-detail">Festival Kiada — Inauguración</span>
      </div>
      <div class="presence-item">
        <span class="presence-year marginalia">2024</span>
        <span class="presence-place">Alemania</span>
        <span class="presence-detail">Festival de Kirchheimbolanden</span>
      </div>
      <div class="presence-item">
        <span class="presence-year marginalia">2025</span>
        <span class="presence-place">Madrid</span>
        <span class="presence-detail">Madrid en Danza, Teatros del Canal</span>
      </div>
      <div class="presence-item">
        <span class="presence-year marginalia">2026</span>
        <span class="presence-place">Arles</span>
        <span class="presence-detail">Théâtre Antique d'Arles</span>
      </div>
    </div>
  </section>

  <!-- La Tulpa -->
  <section class="section container home-tulpa" aria-labelledby="home-tulpa-title">
    <div class="tulpa-grid reveal">
      <div class="tulpa-main">
        <span class="marginalia">Compañía</span>
        <h2 id="home-tulpa-title" class="accent-underline">La Tulpa</h2>
        <p>
          En la tradición tibetana, una tulpa es un ser que cobra forma a través del pensamiento y la voluntad. Un pensamiento que se hace cuerpo. Fundada en 2023 en colaboración con Danza Mobile, Sevilla.
        </p>
        <a href="/obra/la-tulpa" class="cta-link">Conocer La Tulpa &rarr;</a>
      </div>
      <div class="tulpa-aside">
        <img class="tulpa-logo chaos-tilt" src="/images/la-tulpa-logo.jpg" alt="Logo de La Tulpa" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="section container home-cta" aria-labelledby="home-contact">
    <div class="reveal">
      <span class="marginalia">Contratación y programación</span>
      <h2 id="home-contact" class="accent-underline">Contacto</h2>
      <p class="cta-text">
        Para programar funciones, solicitar dossier o rider técnico, o cualquier consulta sobre Manuel Monrò y La Tulpa.
      </p>
      <a href="mailto:cialatulpa@gmail.com" class="cta-link cta-link--large">cialatulpa@gmail.com</a>
    </div>
  </section>

  <!-- Final curtain -->
  <div class="final-curtain">
    <div class="final-curtain-line" aria-hidden="true"></div>
    <a href="/nadie" class="final-curtain-text">— Fin de la función —</a>
  </div>
</Base>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Dramatic interstitial */
  .interstitial {
    position: relative;
    background-color: #000;
    padding-block: var(--space-xl);
    overflow: hidden;
  }

  @media (min-width: 48rem) {
    .interstitial {
      padding-block: var(--space-2xl);
    }
  }

  .interstitial::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 4rem;
    background: linear-gradient(to bottom, transparent, var(--color-accent-solid));
  }

  .interstitial-inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-md);
    text-align: center;
  }

  .interstitial-text {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 3rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.5;
    color: rgba(236, 231, 222, 0.85);
    letter-spacing: 0.01em;
  }

  .interstitial-accent {
    color: var(--color-accent-interactive);
  }

  .interstitial-source {
    display: block;
    margin-top: var(--space-md);
    font-style: italic;
  }

  /* Identity */
  .identity-statement {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.5rem);
    font-weight: 400;
    line-height: 1.35;
    color: var(--color-text);
    max-width: var(--content-width);
    margin-bottom: var(--space-lg);
  }

  .disciplines {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .discipline-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-warm-grey);
    padding: 0.4em 1em;
    border-radius: 2px;
  }

  /* Approach */
  .approach-grid {
    display: grid;
    gap: var(--space-lg);
  }

  @media (min-width: 48rem) {
    .approach-grid {
      grid-template-columns: 1.5fr 1fr;
      align-items: start;
    }
  }

  .home-approach {
    border-top: 1px solid var(--color-warm-grey);
  }

  .approach-text {
    font-size: 1.125rem;
    line-height: 1.7;
    max-width: var(--content-width);
    margin-bottom: var(--space-sm);
  }

  .approach-text--emphasis {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.25rem;
    color: var(--color-text);
    margin-top: var(--space-md);
  }

  .approach-quote {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-style: italic;
    color: var(--color-text);
    border-left: 3px solid var(--color-bronze, var(--color-accent-solid));
    padding-left: var(--space-md);
    margin-bottom: var(--space-xs);
    line-height: 1.5;
  }

  @media (min-width: 48rem) {
    .approach-aside {
      padding-top: var(--space-md);
    }
  }

  /* Featured work */
  .work-header {
    margin-bottom: var(--space-md);
  }

  .work-header .marginalia {
    display: block;
    margin-bottom: var(--space-xs);
  }

  .home-work-card {
    display: grid;
    gap: var(--space-md);
    overflow: hidden;
    border-radius: 2px;
    background-color: var(--color-base-raised);
  }

  @media (min-width: 48rem) {
    .home-work-card {
      grid-template-columns: 1.2fr 1fr;
    }
  }

  .work-card-media {
    position: relative;
    overflow: hidden;
  }

  .work-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 16 / 10;
  }

  @media (prefers-reduced-motion: no-preference) {
    .work-card-media:hover .work-card-img,
    .work-card-media:hover .empty-media {
      transform: scale(1.03);
      transition: transform 0.8s ease-out;
    }
  }

  .work-card-info {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-xs);
  }

  @media (min-width: 48rem) {
    .work-card-info {
      padding: var(--space-lg) var(--space-md);
    }
  }

  .work-card-info .label {
    align-self: flex-start;
  }

  .work-card-info h3 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
  }

  .work-card-info h3 a {
    color: var(--color-text);
    background-image: none;
    transition: color var(--transition-fast);
  }

  .work-card-info h3 a:hover {
    color: var(--color-accent-interactive);
  }

  .work-card-meta {
    font-size: 0.8rem;
  }

  .work-card-desc {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
  }

  .work-card-link {
    font-size: 0.875rem;
    margin-top: var(--space-xs);
  }

  /* International presence */
  .home-presence {
    border-top: 1px solid var(--color-warm-grey);
  }

  .presence-grid {
    display: grid;
    gap: 0;
    margin-top: var(--space-md);
  }

  @media (min-width: 48rem) {
    .presence-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 64rem) {
    .presence-grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .presence-item {
    padding: var(--space-md);
    border-bottom: 1px solid var(--color-warm-grey);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  @media (min-width: 48rem) {
    .presence-item {
      border-bottom: none;
      border-right: 1px solid var(--color-warm-grey);
    }

    .presence-item:last-child {
      border-right: none;
    }
  }

  .presence-place {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .presence-detail {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  /* La Tulpa */
  .home-tulpa {
    border-top: 1px solid var(--color-warm-grey);
  }

  .tulpa-grid {
    display: grid;
    gap: var(--space-lg);
    align-items: center;
  }

  @media (min-width: 48rem) {
    .tulpa-grid {
      grid-template-columns: 1.5fr 1fr;
    }
  }

  .tulpa-main .marginalia {
    display: block;
    margin-bottom: var(--space-xs);
  }

  .tulpa-main p {
    margin-top: var(--space-sm);
    max-width: 36rem;
    color: var(--color-text-secondary);
  }

  .tulpa-logo {
    max-width: 14rem;
    margin-left: auto;
    border-radius: 2px;
  }

  /* Contact CTA */
  .home-cta {
    text-align: center;
    border-top: 1px solid var(--color-warm-grey);
  }

  .home-cta .marginalia {
    display: block;
    margin-bottom: var(--space-xs);
  }

  .cta-text {
    max-width: 32rem;
    margin-inline: auto;
    margin-top: var(--space-sm);
    color: var(--color-text-secondary);
  }

  .cta-link {
    display: inline-block;
    margin-top: var(--space-md);
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--color-accent-interactive);
    background-image: none;
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: 0.2rem;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .cta-link:hover {
    color: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
  }

  .cta-link--large {
    font-size: 1.35rem;
    border-bottom-width: 3px;
  }

  /* Performance counter */
  .counter {
    background-color: var(--color-base-raised);
    border-top: 3px solid var(--color-accent-solid);
    border-bottom: 3px solid var(--color-accent-solid);
    padding-block: var(--space-lg);
  }

  .counter-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .counter-item {
    text-align: center;
  }

  .counter-number {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 700;
    line-height: 1;
    color: var(--color-text);
  }

  .counter-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  .counter-divider {
    width: 1px;
    height: 3rem;
    background-color: var(--color-warm-grey);
  }

  .counter-item--accent {
    display: flex;
    align-items: center;
  }

  .counter-status {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-style: italic;
    color: var(--color-accent-interactive);
  }

  @media (max-width: 30rem) {
    .counter-divider { display: none; }
    .counter-inner { gap: var(--space-md); }
  }

  /* Final curtain */
  .final-curtain {
    padding: var(--space-xl) 0 var(--space-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .final-curtain-line {
    width: 1px;
    height: 6rem;
    background: linear-gradient(to bottom, transparent, var(--color-accent-solid));
  }

  .final-curtain-text {
    font-family: var(--font-display);
    font-size: 1rem;
    font-style: italic;
    color: var(--color-accent-interactive);
    opacity: 0.7;
    letter-spacing: 0.1em;
    background-image: none;
    transition: opacity var(--transition-fast);
  }

  .final-curtain-text:hover {
    opacity: 1;
    background-image: none;
  }
</style>
