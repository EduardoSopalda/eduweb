---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import { getCollection, render } from 'astro:content';

const obras = (await getCollection('obras')).sort((a, b) => (b.data.order || 0) - (a.data.order || 0));
const featured = obras.find((o) => o.data.touring) || obras[0];
---

<Base
  title="Inicio"
  description="Manuel Monró — coreógrafo, intérprete y director de La Tulpa. Danza contemporánea, danza teatro y creación inclusiva."
>
  <Hero
    title="Manuel Monró"
    phrase="Un pensamiento que se hace cuerpo."
    height="full"
  />

  <section class="section container home-intro" aria-labelledby="home-statement">
    <div class="home-intro-grid">
      <div class="home-intro-main reveal">
        <h2 id="home-statement" class="accent-underline">Coreógrafo. Intérprete. Creador.</h2>
        <p>
          Manuel Monró trabaja en el cruce entre danza contemporánea, danza teatro y creación inclusiva. Fundó La Tulpa en 2023, dentro del Festival Internacional Escena Mobile de Arte y Diversidad en Sevilla.
        </p>
        <p>
          Un lugar donde el cuerpo investiga lo que las palabras no alcanzan.
        </p>
      </div>
      <aside class="home-intro-aside reveal reveal-delay-1">
        <p class="marginalia marginalia--offset">
          &ldquo;Casi nadie se pregunta si es más real lo que se puede ver, lo que se puede oír, o lo que se contiene.&rdquo;
        </p>
      </aside>
    </div>
  </section>

  {featured && (
    <section class="section container" aria-labelledby="home-work-title">
      <span class="marginalia reveal">En escena</span>
      <h2 id="home-work-title" class="accent-underline reveal">{featured.data.title}</h2>
      <div class="home-work-card reveal reveal-delay-1">
        <div class="work-card-media">
          {featured.data.image
            ? <img class="work-card-img" src={featured.data.image} alt={featured.data.title} loading="lazy" />
            : <div class="empty-media empty-media--landscape" aria-hidden="true"></div>
          }
        </div>
        <div class="work-card-info">
          {featured.data.touring && <span class="label">En gira</span>}
          <h3>
            <a href={`/obra/${featured.data.slug}`}>{featured.data.title}</a>
          </h3>
          <p class="work-card-meta marginalia">
            {featured.data.year} — {featured.data.type}
          </p>
          <a href="/obra" class="work-card-link">Ver obra completa &rarr;</a>
        </div>
      </div>
    </section>
  )}

  <section class="section container home-cta" aria-labelledby="home-contact">
    <div class="reveal">
      <h2 id="home-contact" class="accent-underline">Contacto</h2>
      <p class="prose">
        Para contratación, programación de funciones o cualquier consulta.
      </p>
      <a href="/contacto" class="cta-link">Contactar &rarr;</a>
    </div>
  </section>
</Base>

<style>
  .home-intro-grid {
    display: grid;
    gap: var(--space-lg);
  }

  @media (min-width: 48rem) {
    .home-intro-grid {
      grid-template-columns: 2fr 1fr;
      align-items: start;
    }
  }

  .home-intro-main {
    max-width: var(--content-width);
  }

  .home-intro-main h2 {
    margin-bottom: var(--space-md);
  }

  .home-intro-aside {
    padding-top: var(--space-sm);
  }

  @media (min-width: 48rem) {
    .home-intro-aside {
      padding-top: var(--space-lg);
      border-left: 1px solid var(--color-warm-grey);
      padding-left: var(--space-md);
    }
  }

  .home-work-card {
    display: grid;
    gap: var(--space-md);
    margin-top: var(--space-md);
    overflow: hidden;
    border-radius: 2px;
    background-color: var(--color-base-raised);
  }

  @media (min-width: 48rem) {
    .home-work-card {
      grid-template-columns: 1.2fr 1fr;
    }
  }

  .work-card-media {
    position: relative;
    overflow: hidden;
  }

  .work-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 16 / 10;
  }

  @media (prefers-reduced-motion: no-preference) {
    .work-card-media:hover .work-card-img,
    .work-card-media:hover .empty-media {
      transform: scale(1.03);
      transition: transform 0.8s ease-out;
    }
  }

  .work-card-info {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-xs);
  }

  @media (min-width: 48rem) {
    .work-card-info {
      padding: var(--space-lg) var(--space-md);
    }
  }

  .work-card-info .label {
    align-self: flex-start;
  }

  .work-card-info h3 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
  }

  .work-card-info h3 a {
    color: var(--color-text);
    background-image: none;
    transition: color var(--transition-fast);
  }

  .work-card-info h3 a:hover {
    color: var(--color-accent-interactive);
  }

  .work-card-meta {
    font-size: 0.8rem;
  }

  .work-card-link {
    font-size: 0.875rem;
    margin-top: var(--space-sm);
  }

  .home-cta {
    text-align: center;
  }

  .home-cta .prose {
    margin-inline: auto;
  }

  .cta-link {
    display: inline-block;
    margin-top: var(--space-md);
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-accent-interactive);
    background-image: none;
    border-bottom: 3px solid var(--color-accent);
    padding-bottom: 0.25rem;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .cta-link:hover {
    color: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
  }
</style>
