---
import Base from '../../layouts/Base.astro';
import ImagePlaceholder from '../../components/ImagePlaceholder.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const obras = await getCollection('obras');
  return obras.map((obra) => ({
    params: { slug: obra.data.slug },
    props: { obra },
  }));
}

const { obra } = Astro.props;
const { Content } = await render(obra);
const d = obra.data;
---

<Base
  title={d.title}
  description={`${d.title} (${d.year}). ${d.type}. Coreografía de ${d.choreography}.`}
>
  <article class="section container">
    <div class="obra-header reveal">
      <a href="/obras" class="obra-back">&larr; Volver a obras</a>
      <span class="accent-line"></span>
      <h1>{d.title}</h1>
      <p class="obra-year">{d.year}</p>
    </div>

    <div class="obra-layout">
      <div class="obra-media reveal">
        <ImagePlaceholder
          aspect="16/9"
          label={`[Fotografía de ${d.title} — pendiente de Manuel]`}
        />
      </div>

      <div class="obra-details reveal">
        <dl class="obra-ficha">
          <dt>Coreografía</dt>
          <dd>{d.choreography}</dd>
          <dt>Interpretación</dt>
          <dd>{d.performers}</dd>
          <dt>Música</dt>
          <dd>{d.music}</dd>
          <dt>Producción</dt>
          <dd>{d.production}</dd>
          <dt>Estreno</dt>
          <dd>{d.premiere}</dd>
          <dt>Formato</dt>
          <dd>{d.type}</dd>
        </dl>
        {d.touring && (
          <span class="obra-touring-badge">En gira</span>
        )}
      </div>
    </div>

    <div class="obra-body prose reveal">
      <Content />
    </div>
  </article>
</Base>

<style>
  .obra-back {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-bottom: var(--space-md);
    transition: color var(--transition-fast);
  }

  .obra-back:hover {
    color: var(--color-accent-interactive);
  }

  .obra-year {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  .obra-layout {
    display: grid;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  @media (min-width: 48rem) {
    .obra-layout {
      grid-template-columns: 1.5fr 1fr;
    }
  }

  .obra-ficha {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem var(--space-md);
  }

  .obra-ficha dt {
    font-weight: 600;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .obra-ficha dd {
    margin: 0;
  }

  .obra-touring-badge {
    display: inline-block;
    margin-top: var(--space-md);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-interactive);
    border: 1px solid var(--color-accent);
    padding: 0.2em 0.6em;
    border-radius: 2px;
  }

  .obra-body {
    margin-top: var(--space-lg);
    border-top: 1px solid var(--color-accent);
    padding-top: var(--space-lg);
  }

  .obra-body :global(h2) {
    font-size: 1.5rem;
    margin-top: var(--space-lg);
  }

  .obra-body :global(h3) {
    font-size: 1.25rem;
    margin-top: var(--space-md);
  }

  .obra-body :global(li) {
    margin-bottom: 0.5rem;
  }

  .obra-body :global(em) {
    font-style: italic;
  }
</style>
