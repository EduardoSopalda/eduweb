---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const obras = await getCollection('obras');
  return obras.map((obra) => ({
    params: { slug: obra.data.slug },
    props: { obra },
  }));
}

const { obra } = Astro.props;
const { Content } = await render(obra);
const d = obra.data;
---

<Base
  title={d.title}
  description={`${d.title} (${d.year}). ${d.type}. Coreografía de ${d.choreography}.`}
>
  <!-- ASSET: Replace with production photo (image prop) when available -->
  <Hero title={d.title} subtitle={String(d.year)} height="section" />

  <article class="section container">
    <div class="obra-header reveal">
      <a href="/obras" class="obra-back">&larr; Volver a obras</a>
    </div>

    <div class="obra-layout">
      <div class="obra-media reveal">
        <!-- ASSET: Replace with production photo or video -->
        <div class="obra-media-empty" aria-hidden="true"></div>
      </div>

      <div class="obra-details reveal reveal-delay-1">
        {d.touring && <span class="label" style="margin-bottom: var(--space-md); display: inline-block;">En gira</span>}
        <dl class="obra-ficha">
          <dt>Coreografía</dt>
          <dd>{d.choreography}</dd>
          <dt>Interpretación</dt>
          <dd>{d.performers}</dd>
          <dt>Música</dt>
          <dd>{d.music}</dd>
          <dt>Producción</dt>
          <dd>{d.production}</dd>
          <dt>Estreno</dt>
          <dd>{d.premiere}</dd>
          <dt>Formato</dt>
          <dd>{d.type}</dd>
        </dl>
      </div>
    </div>

    <div class="obra-body prose reveal reveal-delay-2">
      <Content />
    </div>
  </article>
</Base>

<style>
  .obra-back {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    background-image: none;
    margin-bottom: var(--space-md);
    transition: color var(--transition-fast);
  }

  .obra-back:hover {
    color: var(--color-accent-interactive);
  }

  .obra-layout {
    display: grid;
    gap: var(--space-lg);
    margin-top: var(--space-md);
  }

  @media (min-width: 48rem) {
    .obra-layout {
      grid-template-columns: 1.5fr 1fr;
    }
  }

  .obra-media-empty {
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: 2px;
    background:
      radial-gradient(ellipse at 40% 50%, #1a1520 0%, transparent 60%),
      linear-gradient(165deg, #0f0e12, #0B0B0D 50%, #100d14);
  }

  .obra-ficha {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem var(--space-md);
    padding: var(--space-md);
    background-color: var(--color-base-raised);
    border-left: 4px solid var(--color-accent-solid);
    border-radius: 2px;
  }

  .obra-ficha dt {
    font-weight: 700;
    color: var(--color-text-secondary);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .obra-ficha dd {
    margin: 0;
  }

  .obra-body {
    margin-top: var(--space-xl);
    border-top: 1px solid var(--color-warm-grey);
    padding-top: var(--space-lg);
  }

  .obra-body :global(h2) {
    font-size: 1.5rem;
    margin-top: var(--space-lg);
  }

  .obra-body :global(h3) {
    font-size: 1.25rem;
    margin-top: var(--space-md);
  }

  .obra-body :global(li) {
    margin-bottom: 0.5rem;
  }
</style>
