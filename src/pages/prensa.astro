---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
---

<Base
  title="Prensa"
  description="Reseñas y notas de prensa sobre el trabajo de Manuel Monró y La Tulpa."
>
  <Hero title="Prensa" height="section" />

  <section class="section container">
    <div class="prose reveal">
      <p>
        Fragmentos seleccionados de reseñas y notas de medios sobre el trabajo de Manuel Monró y La Tulpa.
      </p>
    </div>

    <div class="press-list">
      <article class="press-item reveal reveal-delay-1">
        <blockquote>
          <p>
            &laquo;La estética puede resultar siniestra, pero estos seres son inofensivos.&raquo;
          </p>
        </blockquote>
        <p class="press-source marginalia">
          Reseña de <em>Ensayo sobre nadie</em>, a raíz de su estreno en la XVI edición del Festival Escena Mobile, Sevilla, 2023.
        </p>
        <!-- PENDING: author and publication for proper attribution -->
      </article>
    </div>
    <!-- PENDING: additional reviews and press coverage -->
  </section>
</Base>

<style>
  .press-list {
    margin-top: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .press-item blockquote {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    border-left: 3px solid var(--color-accent-solid);
    padding-left: var(--space-md);
    color: var(--color-text);
    font-style: italic;
    margin-bottom: var(--space-md);
    line-height: 1.4;
  }

  .press-source {
    padding-left: calc(var(--space-md) + 3px);
  }
</style>
